ifelse(is_mounted("/nvdata"),unmount("/nvdata"));
ifelse(is_mounted("/nvcfg"),unmount("/nvcfg"));
ifelse(is_mounted("/protect_f"),unmount("/protect_f"));
ifelse(is_mounted("/protect_s"),unmount("/protect_s"));

###
#
#--- Generic Script
#
###
setconfig("package_name","Mediatek NVTool");
setconfig("package_build","1.0.1-2026");
setconfig("package_date","2023-07-04");
setconfig("package_author","Str33t10");
font(
	0,
	"assets/fonts/RobotoCondensed-Regular.ttf",
	12
);
font(
	1,
	"assets/fonts/RobotoCondensed-Bold.ttf",
	18
);
splash(
	1,
	"assets/images/cursor",
	750
);
eula(
	getconfig("package_name"),
	"Legal Information (EULA)",
	"assets/images/print",
 	package_read_file("assets/common/license.txt"),
	"Agree the terms of services",
	"You need to agree the end-user license agreement!"
);
menu(
	getconfig("package_name"),
	"Internal Strorage ("+free_getdisk("/sdcard","m")+" MB)",
	"assets/images/settings",
	getprop("ro.product.device"),
	"Backup",">>","assets/images/person",
	"Restore","<<","assets/images/home",
	"Remove","<>","assets/images/eye",
	"Reboot",getprop("ro.product.model"),"assets/images/android"
);
if file_getprop("/tmp/"+getprop("ro.product.device"),"selected")=="1" then
	if read_file("/sdcard/"+getprop("ro.product.device")+"/nvram.md5")!="" then
		okay(
			getconfig("package_name"),
			getprop("ro.product.model")+" backup already exist!",
			"assets/images/warning"
		);
		back(getvalue("0"));
	endif;
	if yesno(
		getconfig("package_name"),
		"Do you want to create a backup "+getprop("ro.product.model")+"?",
		"assets/images/question"
	)=="yes" then
		write_value(
			"/tmp/"+getprop("ro.product.device"),
			"mkdir -p /sdcard/"+getprop("ro.product.device")+"\n"+
			"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /proinfo | grep -o '/dev/[^ ]*' | head -1`\n"+
			"[ -n $block ] && dd if=$block of=/sdcard/"+getprop("ro.product.device")+"/proinfo.bin\n"+
			"[ $? == 0 ] && md5sum /sdcard/"+getprop("ro.product.device")+"/proinfo.bin | tee /sdcard/"+getprop("ro.product.device")+"/proinfo.md5\n"+
			"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /protect_f | grep -o '/dev/[^ ]*' | head -1`\n"+
			"[ -n $block ] && dd if=$block of=/sdcard/"+getprop("ro.product.device")+"/protect_f.img\n"+
			"[ $? == 0 ] && md5sum /sdcard/"+getprop("ro.product.device")+"/protect_f.img | tee /sdcard/"+getprop("ro.product.device")+"/protect_f.md5\n"+
			"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /protect_s | grep -o '/dev/[^ ]*' | head -1`\n"+
			"[ -n $block ] && dd if=$block of=/sdcard/"+getprop("ro.product.device")+"/protect_s.img\n"+
			"[ $? == 0 ] && md5sum /sdcard/"+getprop("ro.product.device")+"/protect_s.img | tee /sdcard/"+getprop("ro.product.device")+"/protect_s.md5\n"+
			"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /nvcfg | grep -o '/dev/[^ ]*' | head -1`\n"+
			"[ -n $block ] && dd if=$block of=/sdcard/"+getprop("ro.product.device")+"/nvcfg.img\n"+
			"[ $? == 0 ] && md5sum /sdcard/"+getprop("ro.product.device")+"/nvcfg.img | tee /sdcard/"+getprop("ro.product.device")+"/nvcfg.md5\n"+
			"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /nvdata | grep -o '/dev/[^ ]*' | head -1`\n"+
			"[ -n $block ] && dd if=$block of=/sdcard/"+getprop("ro.product.device")+"/nvdata.img\n"+
			"[ $? == 0 ] && md5sum /sdcard/"+getprop("ro.product.device")+"/nvdata.img | tee /sdcard/"+getprop("ro.product.device")+"/nvdata.md5\n"+
			"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /nvram | grep -o '/dev/[^ ]*' | head -1`\n"+
			"[ -n $block ] && dd if=$block of=/sdcard/"+getprop("ro.product.device")+"/nvram.bin\n"+
			"[ $? == 0 ] && md5sum /sdcard/"+getprop("ro.product.device")+"/nvram.bin | tee /sdcard/"+getprop("ro.product.device")+"/nvram.md5"
		);
		if run_program("/sbin/sh","/tmp/"+getprop("ro.product.device"))=="0" then
			write_value("/tmp/recovery.log",read_file("/tmp/recovery.log")+getvalue("run_program"));
			run_program("/sbin/cp","-f","/tmp/recovery.log","/sdcard/"+getprop("ro.product.device"));	
			okay(
				getconfig("package_name"),
				getprop("ro.product.model")+" backup creating has been done!",
				"assets/images/information"
			);
			back(getvalue("0"));
		else
			run_program("/sbin/rm","-rf","/sdcard/"+getprop("ro.product.device"));
			back(getvalue("0"));
		endif;
	else
		back(getvalue("0"));
	endif;
endif;
if file_getprop("/tmp/"+getprop("ro.product.device"),"selected")=="2" then
	if read_file("/sdcard/"+getprop("ro.product.device")+"/nvram.md5")!="" then
		if yesno(
			getconfig("package_name"),
			"Do you want to restore the backup "+getprop("ro.product.model")+"?",
			"assets/images/question"
		)=="yes" then
			write_value(
				"/tmp/"+getprop("ro.product.device"),
				"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /proinfo | grep -o '/dev/[^ ]*' | head -1`\n"+
				"[ -n $block ] && md5sum -c /sdcard/"+getprop("ro.product.device")+"/proinfo.md5\n"+
				"[ $? == 0 ] && dd if=/sdcard/"+getprop("ro.product.device")+"/proinfo.bin of=$block\n"+
				"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /protect_f | grep -o '/dev/[^ ]*' | head -1`\n"+
				"[ -n $block ] && md5sum -c /sdcard/"+getprop("ro.product.device")+"/protect_f.md5\n"+
				"[ $? == 0 ] && dd if=/sdcard/"+getprop("ro.product.device")+"/protect_f.img of=$block\n"+
				"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /protect_s | grep -o '/dev/[^ ]*' | head -1`\n"+
				"[ -n $block ] && md5sum -c /sdcard/"+getprop("ro.product.device")+"/protect_s.md5\n"+
				"[ $? == 0 ] && dd if=/sdcard/"+getprop("ro.product.device")+"/protect_s.img of=$block\n"+
				"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /nvcfg | grep -o '/dev/[^ ]*' | head -1`\n"+
				"[ -n $block ] && md5sum -c /sdcard/"+getprop("ro.product.device")+"/nvcfg.md5\n"+
				"[ $? == 0 ] && dd if=/sdcard/"+getprop("ro.product.device")+"/nvcfg.img of=$block\n"+
				"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /nvdata | grep -o '/dev/[^ ]*' | head -1`\n"+
				"[ -n $block ] && md5sum -c /sdcard/"+getprop("ro.product.device")+"/nvdata.md5\n"+
				"[ $? == 0 ] && dd if=/sdcard/"+getprop("ro.product.device")+"/nvdata.img of=$block\n"+
				"block=`cat /etc/recovery.fstab | cut -d '#' -f 1 | grep /nvram | grep -o '/dev/[^ ]*' | head -1`\n"+
				"[ -n $block ] && md5sum -c /sdcard/"+getprop("ro.product.device")+"/nvram.md5\n"+
				"[ $? == 0 ] && dd if=/sdcard/"+getprop("ro.product.device")+"/nvram.bin of=$block"
			);
			if run_program("/sbin/sh","/tmp/"+getprop("ro.product.device"))=="0" then
				write_value("/tmp/recovery.log",read_file("/tmp/recovery.log")+getvalue("run_program"));
				run_program("/sbin/cp","-f","/tmp/recovery.log","/sdcard/"+getprop("ro.product.device"));	
				okay(
					getconfig("package_name"),
					getprop("ro.product.model")+" backup restoring has been done!",
					"assets/images/information"
				);
				back(getvalue("0"));
			else
				back(getvalue("0"));
			endif;
		else
			back(getvalue("0"));
		endif;
	else
		okay(
			getconfig("package_name"),
			getprop("ro.product.model")+" backup not found!",
			"assets/images/warning"
		);
		back(getvalue("0"));
	endif;
endif;
if file_getprop("/tmp/"+getprop("ro.product.device"),"selected")=="3" then
	if read_file("/sdcard/"+getprop("ro.product.device")+"/nvram.md5")!="" then
		if yesno(
			getconfig("package_name"),
			"Do you want to erase the backup "+getprop("ro.product.model")+"?",
			"assets/images/question"
		)=="yes" then
			if run_program("/sbin/rm","-rf","/sdcard/"+getprop("ro.product.device"))=="0" then
				okay(
					getconfig("package_name"),
					getprop("ro.product.model")+" backup erasing has been done!",
					"assets/images/information"
				);
				back(getvalue("0"));
			else
				back(getvalue("0"));
			endif;
		else
			back(getvalue("0"));
		endif;
	else
		okay(
			getconfig("package_name"),
			getprop("ro.product.model")+" backup not found!",
			"assets/images/warning"
		);
		back(getvalue("0"));
	endif;
endif;
if file_getprop("/tmp/"+getprop("ro.product.device"),"selected")=="4" then
	setconfig("text_next",getconfig("text_finish"));
	setconfig("icon_next","assets/images/circle");
	radio(
		getconfig("package_name"),
		"Reboot Device ("+getprop("ro.product.model")+")",
		"assets/images/adb",
		getprop("ro.product.device"),
		"reboot","Select mode that you want to reboot","\t","group",
		"android","System","Android","select",
		"recovery","Recovery","Restart","select",
		"fastboot","Bootloader","Fastboot","select",
		"shutdown","Poŵer off","Shutdown","select.selected"
	);
endif;
ifelse(file_getprop("/tmp/"+getprop("ro.product.device"),"reboot")=="android",reboot("now"));
ifelse(file_getprop("/tmp/"+getprop("ro.product.device"),"reboot")=="recovery",reboot("","recovery"));
ifelse(file_getprop("/tmp/"+getprop("ro.product.device"),"reboot")=="fastboot",reboot("","bootloader"));
ifelse(file_getprop("/tmp/"+getprop("ro.product.device"),"reboot")=="shutdown",reboot("now","poweroff"));
